    {
      "name": "12 Get Deleted Record Returns 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('deleted record is not found', function () {",
              "  pm.response.to.have.status(404);",
              "  const json = pm.response.json();",
              "  pm.expect(json.meta.result).to.eql('FAIL');",
              "  pm.expect(json.meta.errorCode).to.eql('NOT_FOUND');",
              "});"
            ]
          }
        }
