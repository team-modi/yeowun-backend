        {
          "name": "02 Save Remind",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/reminds",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recordId\": {{recordId}},\n  \"emotionCodes\": [\n    \"슬픈\",\n    \"강렬한\"\n  ],\n  \"reflection\": \"당시엔 강렬했는데, 다시 보니 슬픔이 더 깊게 다가온다.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "리마인드 저장 — 과거 기록에 '지금 다시 보니'의 감정(선택)·소감(필수)을 남긴다. 앞서 만든 recordId 사용. 감정 변화 AI 요약은 best-effort(키 있으면 READY, 없으면 SKIPPED)라 저장은 항상 성공. remindId를 환경변수에 저장한다."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 리마인드는 '기존 기록에 대한 회고'라 현재 로그인 유저 소유의 recordId가 필요하다.",
                  "// Record 단계에서 기록이 삭제되거나 recordId가 오래되면 RECORD_NOT_FOUND(404)가 나므로,",
                  "// 이 요청 직전에 토큰·전시·기록을 확보한다. (기록 생성은 201을 반환 → 2xx 전체를 성공으로 본다.)",
                  "const base = (pm.environment.get('baseUrl') || 'http://localhost:18090').replace(/\\/$/, '');",
                  "const ok = (r) => r && r.code >= 200 && r.code < 300;",
                  "const send = (opts) => new Promise((res) => pm.sendRequest(opts, (e, r) => res(e ? null : r)));",
                  "(async () => {",
                  "  let token = pm.environment.get('accessToken');",
                  "  if (!token) {",
                  "    const r = await send({ url: base + '/api/v1/auth/guest', method: 'POST' });",
                  "    if (ok(r)) { token = r.json().data.accessToken; pm.environment.set('accessToken', token); }",
                  "  }",
                  "  if (!token) return;",
                  "  const auth = { Authorization: 'Bearer ' + token };",
                  "  const exr = await send({ url: base + '/api/v1/exhibitions?page=0&size=1', method: 'GET', header: auth });",
                  "  const list = ok(exr) ? exr.json().data.content : [];",
                  "  if (!list.length) return;",
                  "  const rec = await send({",
                  "    url: base + '/api/v1/records', method: 'POST',",
                  "    header: Object.assign({ 'Content-Type': 'application/json' }, auth),",
                  "    body: { mode: 'raw', raw: JSON.stringify({ exhibitionId: list[0].exhibitionId, writeMode: 'DIRECT', viewedAt: '2026-06-15', content: '리마인드 검수용 기록(자동 생성)', emotionCodes: ['평화로운', '고요한'], media: [] }) }",
                  "  });",
                  "  if (ok(rec)) pm.environment.set('recordId', rec.json().data.recordId);",
                  "})();"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('remind saved', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.remindId).to.be.a('number');",
                  "  pm.expect(d.after.text).to.include('슬픔');",
                  "  pm.expect(['READY', 'SKIPPED', 'FAILED']).to.include(d.aiStatus);",
                  "  pm.environment.set('remindId', d.remindId);",
                  "});"
                ]
              }
            }
          ]
        },
