      ],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// 폴더 단독 실행에도 통과하도록, Remind의 모든 요청 전에 accessToken을 보장한다(없으면 게스트 로그인).",
              "const base = (pm.environment.get('baseUrl') || 'http://localhost:18090').replace(/\\/$/, '');",
              "if (!pm.environment.get('accessToken')) {",
              "  const send = (opts) => new Promise((res) => pm.sendRequest(opts, (e, r) => res(e ? null : r)));",
              "  (async () => {",
              "    const r = await send({ url: base + '/api/v1/auth/guest', method: 'POST' });",
              "    if (r && r.code >= 200 && r.code < 300) pm.environment.set('accessToken', r.json().data.accessToken);",
              "  })();",
              "}"
            ]
          }
        }
      ]
