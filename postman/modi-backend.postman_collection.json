              "raw": "{\n  \"exhibitionId\": {{exhibitionId}},\n  \"writeMode\": \"DIRECT\",\n  \"viewedAt\": \"2026-06-15\",\n  \"content\": \"모네의 색이 따뜻해서 한참 서 있었다.\",\n  \"emotionCodes\": [\n    \"강렬한\",\n    \"서정적인\"\n  ],\n  \"media\": [\n    {\n      \"type\": \"PHOTO\",\n      \"url\": \"https://example.com/image.jpg\",\n      \"sortOrder\": 0,\n      \"sizeBytes\": 1048576\n    }\n  ]\n}",
              "options": {
