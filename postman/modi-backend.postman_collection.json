                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "09 Reject Without Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/records",
            "auth": {
              "type": "noauth"
            },
            "description": "토큰 없이 기록 API 호출 → 401 NO_ACCESS_TOKEN. 인증이 실제로 강제됨을 확인."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// access 토큰은 쿠키로도 전달되므로, '토큰 없음'을 진짜로 검증하려면 쿠키 저장소를 비운다.",
                  "// (이후 요청은 컬렉션 레벨 Bearer 헤더로 인증하므로 영향 없음)",
                  "const base = (pm.environment.get('baseUrl') || 'http://localhost:18090');",
                  "try { pm.cookies.jar().clear(base, function () {}); } catch (e) {}"
                ]
